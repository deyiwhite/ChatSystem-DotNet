<Window x:Class="ChatSystem.Desktop.NewGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新建群聊"
        Width="420"
        Height="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#F2FFFFFF" />
        <SolidColorBrush x:Key="LineBrush" Color="#E9D9FB" />
        <SolidColorBrush x:Key="InkBrush" Color="#3B1F6E" />
        <SolidColorBrush x:Key="MutedBrush" Color="#8B7AAB" />
        <SolidColorBrush x:Key="AccentBrush" Color="#A855F7" />
        <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#C084FC" Offset="0" />
            <GradientStop Color="#818CF8" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Grid Background="{StaticResource PanelBrush}" Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="新建群聊"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{StaticResource InkBrush}"
                   Margin="0,0,0,14" />

        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="群名称" 
                       Foreground="{StaticResource MutedBrush}" 
                       FontSize="13" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <!-- 用 Border 包裹实现圆角，TextBox 本身不动 -->
            <Border BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="2"
                    Background="White"
                    CornerRadius="12"
                    Height="42">
                <TextBox x:Name="GroupNameTextBox"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#3B1F6E"
                         MaxLength="50"
                         FontSize="14" />
            </Border>
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="选择要拉入群聊的好友（可多选）"
                   Foreground="{StaticResource MutedBrush}"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8" />

        <Border Grid.Row="3"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                Background="White"
                CornerRadius="12">
            <ListBox x:Name="FriendsCheckList"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     Padding="8">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="{x:Type ListBoxItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                    <Border Name="Border"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#F3EEFC" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource InkBrush}" />
                                <TextBlock Text="{Binding Username}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedBrush}" />
                            </StackPanel>
                        </CheckBox>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <!-- 取消按钮：白色背景 + 紫色边框 -->
            <Border BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="1"
                    Background="White"
                    CornerRadius="12"
                    Width="90"
                    Height="38"
                    Margin="0,0,12,0">
                <Button x:Name="CancelButton"
                        Content="取消"
                        Background="Transparent"
                        Foreground="{StaticResource InkBrush}"
                        FontSize="14"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="CancelButton_Click" />
            </Border>
            <!-- 创建按钮：紫蓝渐变 -->
            <Border Background="{StaticResource PrimaryGradientBrush}"
                    CornerRadius="12"
                    Width="90"
                    Height="38">
                <Button x:Name="OkButton"
                        Content="创建"
                        Background="Transparent"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="OkButton_Click" />
            </Border>
        </StackPanel>
    </Grid>
</Window>