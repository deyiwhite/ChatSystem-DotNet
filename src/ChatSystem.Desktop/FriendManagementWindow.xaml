<Window x:Class="ChatSystem.Desktop.FriendManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ChatSystem.Desktop"
        Title="好友管理"
        Width="850"
        Height="700"
        MinWidth="800"
        MinHeight="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="Microsoft YaHei UI">

    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E9D9FB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <Grid>
                                <TextBlock x:Name="Placeholder"
                                       Text="输入用户名或昵称搜索..."
                                       Foreground="#C4B5FD"
                                       Padding="10,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False" />
                                <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="10,0"
                                          VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,6" />
            <Setter Property="Background" Value="#A855F7" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,5" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#3B1F6E" />
            <Setter Property="BorderBrush" Value="#E9D9FB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#A855F7" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#F3EEFC" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E9D9FB" />
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1" />
                                <Setter Property="Foreground" Value="#C4B5FD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="70" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#FB7185" />
            <Setter Property="BorderBrush" Value="#FB7185" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ListItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#E9D9FB"
                            BorderThickness="0"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F3EEFC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F3EEFC">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 标题区域 -->
                <Border Grid.Row="0"
                        Background="#FFFFFF"
                        BorderBrush="#E9D9FB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="好友管理"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#3B1F6E" />
                            <TextBlock Text="搜索用户、发送好友申请、管理好友关系"
                                       FontSize="14"
                                       Foreground="#8B7AAB"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="刷新"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="RefreshButton_Click" />
                    </Grid>
                </Border>

                <!-- 搜索用户区域 -->
                <Border Grid.Row="2"
                        Background="#FFFFFF"
                        BorderBrush="#E9D9FB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="查找用户"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#3B1F6E" />
                        <TextBlock Text="输入用户名或昵称搜索可添加的好友"
                                   FontSize="13"
                                   Foreground="#8B7AAB"
                                   Margin="0,2,0,10" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SearchTextBox"
                                     Style="{StaticResource InputStyle}"
                                     Text=""
                                     VerticalContentAlignment="Center"
                                     KeyDown="SearchTextBox_KeyDown" />
                            <Button Grid.Column="2"
                                    Content="搜索"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SearchButton_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 搜索结果区域 -->
                <Border Grid.Row="4"
                        Background="#FFFFFF"
                        BorderBrush="#E9D9FB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="搜索结果"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#3B1F6E" />
                            <TextBlock x:Name="SearchResultsCountTextBlock"
                                       Text="0 个用户"
                                       FontSize="13"
                                       Foreground="#8B7AAB"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel x:Name="SearchEmptyPanel"
                                    Visibility="Visible"
                                    HorizontalAlignment="Center"
                                    Margin="0,20">
                            <TextBlock Text="🔍"
                                       FontSize="48"
                                       Foreground="#E9D9FB"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="输入关键词后可以搜索其他用户"
                                       FontSize="14"
                                       Foreground="#8B7AAB"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>

                        <TextBlock x:Name="SearchNoResultsTextBlock"
                                   Text="没有找到可申请的用户"
                                   Visibility="Collapsed"
                                   FontSize="14"
                                   Foreground="#8B7AAB"
                                   HorizontalAlignment="Center"
                                   Margin="0,20" />

                        <!-- ★ 修复1：Content 绑定改为 ActionText（原来是 ActionButtonText，属性不存在） -->
                        <!-- ★ 修复2：MaxHeight 限制列表高度，内容过多时在列表内滚动 -->
                        <ListBox x:Name="SearchResultsList"
                                 ItemContainerStyle="{StaticResource ListItemStyle}"
                                 Visibility="Collapsed"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="220"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#3B1F6E" />
                                            <TextBlock Text="{Binding Username}"
                                                       FontSize="12"
                                                       Foreground="#8B7AAB" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Content="{Binding ActionText}"
                                                Style="{StaticResource SmallButtonStyle}"
                                                IsEnabled="{Binding CanRequest}"
                                                Tag="{Binding Id}"
                                                VerticalAlignment="Center"
                                                Click="SendRequestButton_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- 我的好友区域 -->
                <Border Grid.Row="6"
                        Background="#FFFFFF"
                        BorderBrush="#E9D9FB"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="我的好友"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#3B1F6E" />
                            <TextBlock x:Name="FriendsCountTextBlock"
                                       Text="0 个好友"
                                       FontSize="13"
                                       Foreground="#8B7AAB"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <StackPanel x:Name="FriendsEmptyPanel"
                                    Visibility="Visible"
                                    HorizontalAlignment="Center"
                                    Margin="0,20">
                            <TextBlock Text="👥"
                                       FontSize="48"
                                       Foreground="#E9D9FB"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="当前还没有好友，先搜索用户并发送好友申请"
                                       FontSize="14"
                                       Foreground="#8B7AAB"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0" />
                        </StackPanel>

                        <ListBox x:Name="FriendsList"
                                 ItemContainerStyle="{StaticResource ListItemStyle}"
                                 Visibility="Collapsed"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="240"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="#3B1F6E" />
                                            <TextBlock Text="{Binding Username}"
                                                       FontSize="12"
                                                       Foreground="#8B7AAB" />
                                        </StackPanel>
                                        <Button Grid.Column="2"
                                                Content="删除好友"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Tag="{Binding Id}"
                                                VerticalAlignment="Center"
                                                Click="DeleteFriendButton_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

            </Grid>
        </ScrollViewer>
    </Grid>
</Window>