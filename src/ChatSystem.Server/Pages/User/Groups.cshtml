@page
@namespace ChatSystem.Server.Pages.UserPages
@model ChatSystem.Server.Pages.UserPages.GroupsModel
@{
    ViewData["Title"] = "群组管理";
}

<div class="group-page">
    <section class="group-hero">
        <div>
            <p class="section-kicker">Groups</p>
            <h1>群组管理</h1>
            <p>创建群聊、邀请好友加入、管理成员，并进入群聊进行多人实时交流。</p>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info">@Model.StatusMessage</div>
    }

    <section class="group-board">
        <div class="group-panel">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">Create</p>
                    <h2>创建群聊</h2>
                </div>
            </div>

            <form method="post" asp-page-handler="Create" class="create-form">
                <input asp-for="NewGroupName" class="form-control" placeholder="输入群名称" maxlength="50" autocomplete="off" />

                @if (Model.Friends.Count == 0)
                {
                    <div class="quiet-box">还没有好友，先去添加好友再创建群聊。</div>
                }
                else
                {
                    <p class="pick-label">选择要拉入群聊的好友（可多选）：</p>
                    <div class="friend-check-list">
                        @foreach (var friend in Model.Friends)
                        {
                            <label class="friend-check">
                                <input type="checkbox" name="MemberIds" value="@friend.Id" />
                                <span class="friend-check-avatar">@(friend.DisplayName.Length > 0 ? friend.DisplayName.Substring(0, 1) : "?")</span>
                                <span>@friend.DisplayName<small>@friend.Username</small></span>
                            </label>
                        }
                    </div>
                }

                <button type="submit" class="btn btn-primary">创建群聊</button>
            </form>
        </div>

        <div class="group-panel">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">My Groups</p>
                    <h2>我的群聊</h2>
                </div>
                <span class="state-chip">@Model.Groups.Count 个</span>
            </div>

            @if (Model.Groups.Count == 0)
            {
                <div class="quiet-box">还没有加入任何群聊。</div>
            }
            else
            {
                <div class="group-list">
                    @foreach (var card in Model.Groups)
                    {
                        <div class="group-card">
                            <div class="group-card-head">
                                <div class="group-card-title">
                                    <span class="group-avatar">@(card.Summary.Name.Length > 0 ? card.Summary.Name.Substring(0, 1) : "群")</span>
                                    <div>
                                        <strong>@card.Summary.Name</strong>
                                        <span>@card.Summary.MemberCount 人 @(card.Summary.IsOwner ? "· 我是群主" : string.Empty)</span>
                                    </div>
                                </div>
                                <a class="btn btn-sm btn-primary" asp-page="/User/GroupChat" asp-route-groupId="@card.Summary.Id">进入群聊</a>
                            </div>

                            <div class="member-chips">
                                @foreach (var member in card.Members)
                                {
                                    <span class="member-chip">
                                        @member.DisplayName@(member.IsOwner ? "（群主）" : string.Empty)
                                        @if (card.Summary.IsOwner && !member.IsOwner)
                                        {
                                            <form method="post" asp-page-handler="RemoveMember">
                                                <input type="hidden" name="groupId" value="@card.Summary.Id" />
                                                <input type="hidden" name="userId" value="@member.UserId" />
                                                <button type="submit" title="移出群聊">×</button>
                                            </form>
                                        }
                                    </span>
                                }
                            </div>

                            <div class="group-card-actions">
                                @if (card.AddableFriends.Count > 0)
                                {
                                    <form method="post" asp-page-handler="AddMember" class="add-member-form">
                                        <input type="hidden" name="groupId" value="@card.Summary.Id" />
                                        <select name="userId" class="form-select form-select-sm">
                                            <option value="0">-- 选择成员 --</option>
                                            @foreach (var friend in card.AddableFriends)
                                            {
                                                <option value="@friend.Id">@friend.DisplayName（@friend.Username）</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-success">添加成员</button>
                                    </form>
                                }

                                @if (card.Summary.IsOwner)
                                {
                                    <form method="post" asp-page-handler="Disband">
                                        <input type="hidden" name="groupId" value="@card.Summary.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">解散群聊</button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Leave">
                                        <input type="hidden" name="groupId" value="@card.Summary.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">退出群聊</button>
                                    </form>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>
</div>

<style>
    .group-page {
        display: grid;
        gap: 20px;
    }

    .group-hero,
    .group-panel,
    .group-card {
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.32);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
    }

    .group-hero {
        padding: 26px 28px;
        box-shadow: 0 16px 36px rgba(120, 80, 200, 0.18);
    }

        .group-hero h1,
        .group-panel h2 {
            margin: 0;
            font-weight: 750;
            color: #3b1f6e;
        }

        .group-hero p {
            margin: 8px 0 0;
            color: #8b7aab;
        }

    .section-kicker {
        margin: 0 0 6px;
        color: #9b7ec9;
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .group-board {
        display: grid;
        grid-template-columns: minmax(0, 380px) minmax(0, 1fr);
        gap: 20px;
        align-items: start;
    }

    .group-panel {
        padding: 22px;
        box-shadow: 0 16px 36px rgba(120, 80, 200, 0.18);
    }

    .panel-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 18px;
    }

    .create-form {
        display: grid;
        gap: 14px;
    }

        .create-form .form-control {
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.6);
            background: rgba(255, 255, 255, 0.55);
            color: #3b1f6e;
            padding: 10px 16px;
        }

            .create-form .form-control:focus {
                border-color: rgba(155, 110, 220, 0.6);
                box-shadow: 0 0 0 .2rem rgba(155, 110, 220, 0.18);
                background: rgba(255, 255, 255, 0.75);
                outline: none;
            }

        .create-form .btn-primary {
            background: linear-gradient(135deg, #c084fc, #60a5fa);
            border: none;
            border-radius: 999px;
            font-weight: 700;
            box-shadow: 0 6px 18px rgba(150, 100, 240, 0.35);
            justify-self: start;
            padding: 8px 22px;
        }

            .create-form .btn-primary:hover {
                background: linear-gradient(135deg, #b06ffa, #4d96f5);
            }

    .pick-label {
        margin: 0;
        color: #8b7aab;
        font-size: .9rem;
    }

    .friend-check-list {
        display: grid;
        gap: 8px;
        max-height: 280px;
        overflow-y: auto;
    }

    .friend-check {
        display: flex;
        align-items: center;
        gap: 10px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.45);
        padding: 8px 12px;
        cursor: pointer;
        transition: background .15s ease, border-color .15s ease;
    }

        .friend-check:hover {
            background: rgba(255, 255, 255, 0.65);
            border-color: rgba(192, 132, 252, 0.5);
        }

    .friend-check-avatar {
        flex-shrink: 0;
        width: 32px;
        height: 32px;
        border-radius: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 13px;
        color: white;
        background: linear-gradient(135deg, #f472b6, #c084fc);
    }

    .friend-check:nth-of-type(3n+2) .friend-check-avatar {
        background: linear-gradient(135deg, #60a5fa, #34d399);
    }

    .friend-check:nth-of-type(3n+3) .friend-check-avatar {
        background: linear-gradient(135deg, #fbbf24, #f87171);
    }

    .friend-check span:not(.friend-check-avatar) {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
        color: #3b1f6e;
    }

    .friend-check small {
        color: #8b7aab;
    }

    .quiet-box {
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.45);
        color: #8b7aab;
        padding: 14px;
    }

    .state-chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(192, 132, 252, 0.3), rgba(96, 165, 250, 0.3));
        color: #6b4ba0;
        font-size: .85rem;
        font-weight: 700;
        padding: 6px 12px;
    }

    .group-list {
        display: grid;
        gap: 14px;
    }

    .group-card {
        padding: 16px;
        background: rgba(255, 255, 255, 0.4);
        transition: transform .15s ease, box-shadow .15s ease;
    }

        .group-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 30px rgba(120, 80, 200, 0.2);
        }

    .group-card-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }

    .group-card-title {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .group-avatar {
        flex-shrink: 0;
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 16px;
        color: white;
        background: linear-gradient(135deg, #a78bfa, #38bdf8);
    }

    .group-card-head strong {
        font-size: 1.05rem;
        color: #3b1f6e;
    }

    .group-card-head span {
        display: block;
        color: #8b7aab;
        font-size: .85rem;
    }

    .group-card .btn-primary {
        background: linear-gradient(135deg, #c084fc, #60a5fa);
        border: none;
        border-radius: 999px;
        font-weight: 700;
    }

        .group-card .btn-primary:hover {
            background: linear-gradient(135deg, #b06ffa, #4d96f5);
        }

    .member-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 12px;
    }

    .member-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.55);
        color: #3b1f6e;
        font-size: .85rem;
        padding: 4px 10px;
    }

        .member-chip form {
            display: inline;
        }

        .member-chip button {
            border: none;
            background: transparent;
            color: #e0567a;
            font-weight: 700;
            cursor: pointer;
            line-height: 1;
            padding: 0;
        }

    .group-card-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 10px;
    }

    .add-member-form {
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .add-member-form .form-select {
            max-width: 220px;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.6);
            background: rgba(255, 255, 255, 0.55);
            color: #3b1f6e;
        }

        .add-member-form .btn-success {
            background: linear-gradient(135deg, #34d399, #60a5fa);
            border: none;
            border-radius: 999px;
            font-weight: 700;
        }

    .group-card-actions .btn-outline-danger {
        border-color: rgba(251, 113, 133, 0.5);
        color: #e0567a;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.4);
    }

        .group-card-actions .btn-outline-danger:hover {
            background: rgba(251, 113, 133, 0.15);
            border-color: rgba(251, 113, 133, 0.7);
            color: #d23a64;
        }

    @@media (max-width: 768px) {
        .group-board {
            grid-template-columns: 1fr;
        }

        .group-card-head {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>
