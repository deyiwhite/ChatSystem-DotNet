@page
@namespace ChatSystem.Server.Pages.UserPages
@model ChatSystem.Server.Pages.UserPages.FriendsModel
@{
    ViewData["Title"] = "好友管理";
}

<div class="friend-page">
    <section class="friend-hero">
        <div>
            <p class="section-kicker">User</p>
            <h1>好友管理</h1>
            <p>搜索已审核通过的普通用户，发送好友申请，或从当前好友列表中删除好友。</p>
        </div>
        <a class="btn btn-outline-primary" asp-page="/User/Requests">查看好友申请</a>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-info">@Model.StatusMessage</div>
    }

    <section class="friend-board">
        <div class="friend-panel">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">Search</p>
                    <h2>查找用户</h2>
                </div>
            </div>

            <form method="get" class="search-row">
                <label asp-for="SearchKeyword" class="visually-hidden"></label>
                <input asp-for="SearchKeyword" class="form-control" placeholder="输入用户名或昵称" autocomplete="off" />
                <button type="submit" class="btn btn-primary">搜索</button>
            </form>

            @if (Model.HasSearched)
            {
                @if (Model.SearchResults.Count == 0)
                {
                    <div class="quiet-box">没有找到可申请的用户。</div>
                }
                else
                {
                    <div class="result-list">
                        @foreach (var user in Model.SearchResults)
                        {
                            <div class="result-item">
                                <div>
                                    <strong>@user.DisplayName</strong>
                                    <span>@user.Username</span>
                                    <small>@user.ActionText</small>
                                </div>
                                @if (user.CanRequest)
                                {
                                    <form method="post" asp-page-handler="SendRequest" asp-route-id="@user.Id">
                                        <input type="hidden" name="SearchKeyword" value="@Model.SearchKeyword" />
                                        <button type="submit" class="btn btn-sm btn-success">申请</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="state-chip">@user.ActionText</span>
                                }
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="quiet-box">输入关键词后可以搜索其他 Active 用户。</div>
            }
        </div>

        <div class="friend-panel">
            <div class="panel-heading">
                <div>
                    <p class="section-kicker">Friends</p>
                    <h2>我的好友</h2>
                </div>
                <span class="state-chip">@Model.Friends.Count 人</span>
            </div>

            @if (Model.Friends.Count == 0)
            {
                <div class="quiet-box">当前还没有好友。先搜索用户并发送好友申请。</div>
            }
            else
            {
                <div class="friend-list">
                    @foreach (var friend in Model.Friends)
                    {
                        <div class="friend-row">
                            <div>
                                <strong>@friend.DisplayName</strong>
                                <span>@friend.Username</span>
                            </div>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@friend.Id">
                                <button type="submit" class="btn btn-sm btn-outline-danger">删除好友</button>
                            </form>
                        </div>
                    }
                </div>
            }
        </div>
    </section>
</div>

<style>
    .friend-page {
        display: grid;
        gap: 20px;
    }

    .friend-hero,
    .friend-panel {
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.32);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 16px 36px rgba(120, 80, 200, 0.18);
    }

    .friend-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 26px 28px;
    }

        .friend-hero h1,
        .friend-panel h2 {
            margin: 0;
            font-weight: 750;
            color: #3b1f6e;
        }

        .friend-hero p {
            margin: 8px 0 0;
            color: #8b7aab;
        }

        .friend-hero .btn-outline-primary {
            border-color: rgba(155, 110, 220, 0.5);
            color: #6b4ba0;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.4);
        }

            .friend-hero .btn-outline-primary:hover {
                background: rgba(192, 132, 252, 0.25);
                border-color: rgba(155, 110, 220, 0.7);
                color: #3b1f6e;
            }

    .section-kicker {
        margin: 0 0 6px;
        color: #9b7ec9;
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .friend-board {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 20px;
    }

    .friend-panel {
        padding: 22px;
    }

    .panel-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 18px;
    }

    .search-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        margin-bottom: 16px;
    }

        .search-row .form-control {
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.6);
            background: rgba(255, 255, 255, 0.55);
            color: #3b1f6e;
            padding: 10px 16px;
        }

            .search-row .form-control:focus {
                border-color: rgba(155, 110, 220, 0.6);
                box-shadow: 0 0 0 .2rem rgba(155, 110, 220, 0.18);
                background: rgba(255, 255, 255, 0.75);
            }

        .search-row .btn-primary {
            background: linear-gradient(135deg, #c084fc, #60a5fa);
            border: none;
            border-radius: 999px;
            font-weight: 700;
            box-shadow: 0 6px 18px rgba(150, 100, 240, 0.35);
        }

            .search-row .btn-primary:hover {
                background: linear-gradient(135deg, #b06ffa, #4d96f5);
            }

    .quiet-box,
    .result-item,
    .friend-row {
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.45);
        padding: 14px;
    }

    .quiet-box {
        color: #8b7aab;
    }

    .result-list,
    .friend-list {
        display: grid;
        gap: 10px;
    }

    .result-item,
    .friend-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

        .result-item strong,
        .friend-row strong {
            color: #3b1f6e;
        }

        .result-item span,
        .friend-row span,
        .result-item small {
            display: block;
            color: #8b7aab;
        }

        .result-item .btn-success {
            background: linear-gradient(135deg, #34d399, #60a5fa);
            border: none;
            border-radius: 999px;
            font-weight: 700;
        }

            .result-item .btn-success:hover {
                background: linear-gradient(135deg, #25c98c, #4d96f5);
            }

        .friend-row .btn-outline-danger {
            border-color: rgba(251, 113, 133, 0.5);
            color: #e0567a;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.4);
        }

            .friend-row .btn-outline-danger:hover {
                background: rgba(251, 113, 133, 0.15);
                border-color: rgba(251, 113, 133, 0.7);
                color: #d23a64;
            }

    .state-chip {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        background: linear-gradient(135deg, rgba(192, 132, 252, 0.3), rgba(96, 165, 250, 0.3));
        color: #6b4ba0;
        font-size: .85rem;
        font-weight: 700;
        padding: 6px 12px;
        white-space: nowrap;
    }

    @@media (max-width: 768px) {
        .friend-hero,
        .result-item,
        .friend-row {
            align-items: stretch;
            flex-direction: column;
        }

        .friend-board,
        .search-row {
            grid-template-columns: 1fr;
        }
    }
</style>
