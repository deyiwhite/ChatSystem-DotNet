@page
@model IndexModel
@{
    ViewData["Title"] = "主页";
    if (User.Identity?.IsAuthenticated != true)
    {
        Response.Redirect("/Account/Login");
        return;
    }
}

@{
    ViewData["Title"] = "主页";
}
@if (User.Identity?.IsAuthenticated == true)
{
    <style>
        .user-shell {
            display: grid;
            gap: 24px;
            padding: 8px 0 32px;
        }

        .user-hero {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            border-radius: 24px;
            background: linear-gradient(135deg, #c084fc 0%, #818cf8 55%, #60a5fa 100%);
            box-shadow: 0 16px 40px rgba(120, 80, 200, 0.28);
            padding: 36px 40px;
            color: white;
            position: relative;
            overflow: hidden;
        }

            .user-hero::before {
                content: '';
                position: absolute;
                width: 320px;
                height: 320px;
                border-radius: 50%;
                background: rgba(255,255,255,0.08);
                top: -80px;
                right: -60px;
                pointer-events: none;
            }

            .user-hero::after {
                content: '';
                position: absolute;
                width: 180px;
                height: 180px;
                border-radius: 50%;
                background: rgba(255,255,255,0.06);
                bottom: -50px;
                left: 200px;
                pointer-events: none;
            }

        .hero-left .eyebrow {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.75);
            margin-bottom: 10px;
        }

        .hero-left h1 {
            font-size: 36px;
            font-weight: 800;
            color: white;
            margin: 0 0 10px;
        }

        .hero-left p {
            color: rgba(255,255,255,0.82);
            margin: 0;
            font-size: 15px;
        }

        .hero-right {
            flex-shrink: 0;
            background: rgba(255,255,255,0.18);
            border: 1px solid rgba(255,255,255,0.35);
            border-radius: 18px;
            padding: 20px 28px;
            text-align: center;
            backdrop-filter: blur(8px);
            min-width: 160px;
            position: relative;
            z-index: 1;
        }

            .hero-right .label {
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 1.5px;
                text-transform: uppercase;
                color: rgba(255,255,255,0.75);
                display: block;
                margin-bottom: 6px;
            }

            .hero-right strong {
                font-size: 20px;
                font-weight: 800;
                color: white;
            }

        .user-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 18px;
        }

        .user-card {
            position: relative;
            border-radius: 20px;
            padding: 26px 24px;
            background: rgba(255,255,255,0.75);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.6);
            box-shadow: 0 10px 28px rgba(120, 80, 200, 0.1);
            text-decoration: none;
            color: #3b1f6e;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 10px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

            .user-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                height: 4px;
                border-radius: 20px 20px 0 0;
            }

            .user-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 18px 40px rgba(120, 80, 200, 0.2);
                color: #3b1f6e;
            }

        .card-gold::before {
            background: linear-gradient(90deg, #fbbf24, #f87171);
        }

        .card-teal::before {
            background: linear-gradient(90deg, #34d399, #60a5fa);
        }

        .card-indigo::before {
            background: linear-gradient(90deg, #818cf8, #60a5fa);
        }

        .card-pink::before {
            background: linear-gradient(90deg, #f472b6, #c084fc);
        }

        .card-ico {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: white;
        }

        .card-gold .card-ico {
            background: linear-gradient(135deg, #fbbf24, #f87171);
        }

        .card-teal .card-ico {
            background: linear-gradient(135deg, #34d399, #60a5fa);
        }

        .card-indigo .card-ico {
            background: linear-gradient(135deg, #818cf8, #60a5fa);
        }

        .card-pink .card-ico {
            background: linear-gradient(135deg, #f472b6, #c084fc);
        }

        .card-badge {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #9b7ec9;
        }

        .user-card strong {
            font-size: 19px;
            font-weight: 800;
            display: block;
        }

        .user-card small {
            font-size: 13px;
            color: #8b7aab;
            line-height: 1.55;
        }

        .card-arrow {
            margin-top: auto;
            font-size: 18px;
            color: #c4b5fd;
            align-self: flex-end;
        }

        @@media (max-width: 1000px) {
            .user-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 600px) {
            .user-hero {
                flex-direction: column;
            }

            .user-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <div class="user-shell">
        <div class="user-hero">
            <div class="hero-left">
                <p class="eyebrow">Home</p>
                <h1>网上沟通交流系统</h1>
                <p>所有常用功能都可以从这里进入，不需要手动输入页面地址。</p>
            </div>
            <div class="hero-right">
                <span class="label">当前用户</span>
                <strong>@(User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name)</strong>
            </div>
        </div>

        <div class="user-grid">
            <a class="user-card card-gold" asp-page="/User/Friends">
                <div class="card-ico">👥</div>
                <span class="card-badge">@Model.FriendCount 位好友</span>
                <strong>好友列表</strong>
                <small>查看好友、搜索用户，并发起好友申请。</small>
                <span class="card-arrow">→</span>
            </a>
            <a class="user-card card-teal" asp-page="/User/Requests">
                <div class="card-ico">✓</div>
                <span class="card-badge">@Model.PendingRequestCount 条待处理</span>
                <strong>好友申请</strong>
                <small>同意或拒绝收到的好友申请。</small>
                <span class="card-arrow">→</span>
            </a>
            <a class="user-card card-indigo" asp-page="/User/Chat">
                <div class="card-ico">💬</div>
                <span class="card-badge">实时会话</span>
                <strong>聊天</strong>
                <small>选择好友，打开实时私聊窗口。</small>
                <span class="card-arrow">→</span>
            </a>
            <a class="user-card card-pink" asp-page="/User/History">
                <div class="card-ico">🔍</div>
                <span class="card-badge">@Model.MessageCount 条可见消息</span>
                <strong>历史消息</strong>
                <small>按好友、关键词和日期查找聊天记录。</small>
                <span class="card-arrow">→</span>
            </a>
        </div>
    </div>
}
else
{
    <section class="dashboard-hero public-hero">
        <div>
            <p class="eyebrow">ChatSystem</p>
            <h1>网上沟通交流系统</h1>
            <p>请先登录。新用户可提交注册申请，等待管理员审核通过后使用聊天功能。</p>
        </div>
        <div class="hero-actions">
            <a class="btn btn-primary" asp-page="/Account/Login">登录</a>
            <a class="btn btn-outline-secondary" asp-page="/Account/Register">注册申请</a>
        </div>
    </section>
    <section class="dashboard-strip">
        <div>
            <span>默认管理员账号</span>
            <strong>@(Model.AdminExists ? "admin / Admin123!" : "未找到")</strong>
        </div>
        <div>
            <span>当前用户记录数</span>
            <strong>@Model.UserCount</strong>
        </div>
        <div>
            <span>SQLite 数据库</span>
            <strong>@Model.DatabasePath</strong>
        </div>
    </section>
}

<style>
    .dashboard-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.32);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 16px 36px rgba(120, 80, 200, 0.18);
        margin: 10px auto 24px;
        padding: 32px;
    }

        .dashboard-hero .eyebrow {
            margin: 0 0 6px;
            color: #9b7ec9;
            font-size: .78rem;
            font-weight: 700;
            letter-spacing: .14em;
            text-transform: uppercase;
        }

        .dashboard-hero h1 {
            margin: 0 0 10px;
            font-weight: 750;
            color: #3b1f6e;
        }

        .dashboard-hero p {
            margin: 0;
            color: #8b7aab;
            max-width: 680px;
        }

    .hero-user {
        min-width: 220px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.45);
        padding: 16px 18px;
    }

        .hero-user span,
        .dashboard-strip span {
            display: block;
            color: #9b7ec9;
            font-size: .82rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

        .hero-user strong {
            display: block;
            margin-top: 4px;
            font-size: 1.15rem;
            color: #3b1f6e;
        }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

        .hero-actions .btn-primary {
            background: linear-gradient(135deg, #c084fc, #60a5fa);
            border: none;
            border-radius: 999px;
            font-weight: 700;
            box-shadow: 0 6px 18px rgba(150, 100, 240, 0.35);
            padding: 8px 24px;
        }

            .hero-actions .btn-primary:hover {
                background: linear-gradient(135deg, #b06ffa, #4d96f5);
            }

        .hero-actions .btn-outline-secondary {
            border-color: rgba(155, 110, 220, 0.4);
            color: #6b4ba0;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.4);
            padding: 8px 24px;
        }

            .hero-actions .btn-outline-secondary:hover {
                background: rgba(192, 132, 252, 0.2);
                border-color: rgba(155, 110, 220, 0.6);
                color: #3b1f6e;
            }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 18px;
    }

    .dashboard-card {
        position: relative;
        display: grid;
        min-height: 210px;
        align-content: start;
        gap: 10px;
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.32);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 14px 34px rgba(120, 80, 200, 0.15);
        color: #3b1f6e;
        overflow: hidden;
        padding: 22px;
        text-decoration: none;
        transition: border-color .15s ease, box-shadow .15s ease, transform .15s ease;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            inset: 0 0 auto;
            height: 5px;
            background: linear-gradient(90deg, #c084fc, #60a5fa);
        }

        .dashboard-card:hover {
            border-color: rgba(255, 255, 255, 0.7);
            box-shadow: 0 18px 42px rgba(120, 80, 200, 0.25);
            color: #3b1f6e;
            transform: translateY(-3px);
        }

        .dashboard-card strong {
            display: block;
            font-size: 1.35rem;
            line-height: 1.2;
            color: #3b1f6e;
        }

        .dashboard-card small {
            color: #8b7aab;
            font-size: .95rem;
            line-height: 1.55;
        }

    .card-icon {
        display: inline-grid;
        place-items: center;
        width: 46px;
        height: 46px;
        border-radius: 14px;
        background: linear-gradient(135deg, #c084fc, #818cf8);
        color: white;
        font-size: 1.35rem;
        font-weight: 800;
    }

    .card-kicker {
        display: block;
        color: #9b7ec9;
        font-size: .82rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .tone-gold .card-icon {
        background: linear-gradient(135deg, #fbbf24, #f87171);
    }

    .tone-moss .card-icon {
        background: linear-gradient(135deg, #34d399, #60a5fa);
    }

    .tone-ink .card-icon {
        background: linear-gradient(135deg, #818cf8, #60a5fa);
    }

    .tone-clay .card-icon {
        background: linear-gradient(135deg, #f472b6, #c084fc);
    }

    .tone-gold::before {
        background: linear-gradient(90deg, #fbbf24, #f87171);
    }

    .tone-moss::before {
        background: linear-gradient(90deg, #34d399, #60a5fa);
    }

    .tone-ink::before {
        background: linear-gradient(90deg, #818cf8, #60a5fa);
    }

    .tone-clay::before {
        background: linear-gradient(90deg, #f472b6, #c084fc);
    }

    .dashboard-strip {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
        margin-top: 20px;
    }

        .dashboard-strip div {
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 16px;
            background: rgba(255, 255, 255, 0.4);
            box-shadow: 0 10px 24px rgba(120, 80, 200, 0.12);
            padding: 16px 18px;
        }

        .dashboard-strip strong {
            display: block;
            margin-top: 4px;
            overflow-wrap: anywhere;
            color: #3b1f6e;
        }

    @@media (max-width: 1100px) {
        .dashboard-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 760px) {
        .dashboard-hero {
            align-items: stretch;
            flex-direction: column;
        }

        .hero-user {
            min-width: 0;
        }

        .dashboard-grid,
        .dashboard-strip {
            grid-template-columns: 1fr;
        }
    }
</style>